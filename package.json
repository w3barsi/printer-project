{
  "name": "printer-project",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "convex dev --start 'vite dev --port 3000 --host'",
    "dev:old": "concurrently -r pnpm:dev:web pnpm:dev:db",
    "dev:web": "vite dev --port 3000 --host",
    "dev:db": "pnpx convex dev --live-component-sources --typecheck-components",
    "start": "node .output/server/index.mjs",
    "start:xargs": "export $(grep -v '^#' .env | xargs) && pnpm start",
    "start:node": "node -r dotenv/config .output/server/index.mjs",
    "build": "vite build",
    "build:cf": "CLOUDFLARE_DEPLOY=true vite build",
    "build:start": "vite build && export $(grep -v '^#' .env | xargs) && pnpm start",
    "serve": "vite preview",
    "preview:cf": "CLOUDFLARE_DEPLOY=true vite preview",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --type-check --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "pnpm format && pnpm lint",
    "prepare": "husky",
    "clean": "rm -rf .tanstack node_modules .nitro .output && pnpm i",
    "deps": "pnpx taze@latest -Ilw",
    "deps:major": "pnpx taze@latest major -Ilw",
    "env": "node sync-env.js",
    "env:prod": "node sync-env.js --prod",
    "dryrun": "pnpx convex deploy --dry-run",
    "deploy": "convex deploy --cmd 'pnpm build:cf && wrangler deploy'",
    "deploy:cf": "pnpm build:cf && wrangler deploy",
    "deploy:cf:dry": "pnpm build:cf && wrangler deploy --dry-run",
    "cf:typegen": "wrangler types",
    "cf:tail": "wrangler tail printer-project"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.12.4",
    "@convex-dev/migrations": "^0.3.5",
    "@convex-dev/r2": "^0.10.2",
    "@convex-dev/react-query": "0.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@formkit/auto-animate": "^0.8.2",
    "@hookform/resolvers": "^5.2.1",
    "@point-of-sale/receipt-printer-encoder": "^3.0.3",
    "@t3-oss/env-core": "^0.13.8",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.26",
    "better-auth": "~1.6.19",
    "better-upload": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.0",
    "convex": "^1.41.0",
    "convex-helpers": "^0.1.119",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "file-saver": "^2.0.5",
    "input-otp": "^1.4.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.525.0",
    "nitro": "npm:nitro-nightly@latest",
    "picocolors": "^1.1.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.8.1",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.62.0",
    "react-hotkeys-hook": "^5.2.1",
    "react-resizable-panels": "^3.0.4",
    "react-to-print": "^3.1.1",
    "recharts": "^3.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@cloudflare/vite-plugin": "^1.42.3",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/devtools-vite": "^0.8.0",
    "@tanstack/eslint-plugin-query": "^5.101.0",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/react-devtools": "^0.10.7",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/w3c-web-usb": "^1.0.13",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "solid-js": "1.9.13",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^5.1.4",
    "web-vitals": "^4.2.4",
    "wrangler": "^4.105.0"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "intent": {
    "skills": [
      "@tanstack/react-query",
      "@tanstack/react-router",
      "@tanstack/react-start"
    ]
  }
}
